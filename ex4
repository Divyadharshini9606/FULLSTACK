<!DOCTYPE html>
<html lang="en" ng-app="studentTodoApp">
<head>
    <meta charset="UTF-8">
    <title> My List</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
</head>
<body ng-controller="StudentTodoController" class="bg-light">
<div class="container mt-5">
    <div class="card shadow">
        <div class="card-body">
            <h3 class="text-center mb-4">🎓 To Do List</h3>
            <div class="row mb-3">
                <div class="col-md-4">
                    <input type="text" class="form-control"
                           placeholder="Enter task"
                           ng-model="newTask">
                </div>
                <div class="col-md-3">
                    <input type="text" class="form-control"
                           placeholder="Subject"
                           ng-model="newSubject">
                </div>

                <div class="col-md-3">
                    <input type="date" class="form-control"
                           ng-model="newDate">
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100"
                            ng-click="addTask()">Add</button>
                </div>
            </div>
            <div class="mb-3 text-center">
                <button class="btn btn-secondary btn-sm me-2"
                        ng-click="filterStatus=''">All</button>
                <button class="btn btn-warning btn-sm me-2"
                        ng-click="filterStatus=false">Pending</button>
                <button class="btn btn-success btn-sm"
                        ng-click="filterStatus=true">Completed</button>
            </div>
            <ul class="list-group">
                <li class="list-group-item d-flex justify-content-between align-items-center"
                    ng-repeat="task in tasks | filter:{completed: filterStatus} | orderBy:'date'">
                    <div>
                        <input type="checkbox" class="form-check-input me-2"
                               ng-model="task.completed">

                        <span ng-class="{'text-decoration-line-through text-muted': task.completed}">
                            <strong>{{task.title}}</strong>
                            <br>
                            <small class="text-primary">
                                📘 {{task.subject}}
                            </small>
                            <br>
                            <small class="text-muted">
                                📅 {{task.date | date:'dd MMM yyyy'}}
                            </small>
                        </span>
                    </div>
                    <button class="btn btn-danger btn-sm"
                            ng-click="deleteTask($index)">
                        Delete
                    </button>
                </li>
            </ul>
            <div class="mt-3 text-center">
                <strong>Total Tasks:</strong> {{tasks.length}}
            </div>
        </div>
    </div>
</div>

<script>
    var app = angular.module("studentTodoApp", []);
    app.controller("StudentTodoController", function($scope) {      
        $scope.tasks = [];       
        $scope.addTask = function() {
            if ($scope.newTask && $scope.newSubject && $scope.newDate) {
                $scope.tasks.push({
                    title: $scope.newTask,
                    subject: $scope.newSubject,
                    completed: false,
                    date: new Date($scope.newDate)
                });
                $scope.newTask = "";
                $scope.newSubject = "";
                $scope.newDate = "";
            }
        };        
        $scope.deleteTask = function(index) {
            $scope.tasks.splice(index, 1);
        };
    });
</script>
</body>
</html>

